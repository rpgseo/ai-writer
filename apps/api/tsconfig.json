{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "types": ["@cloudflare/workers-types"],
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@ai-writer/shared": ["../../packages/shared/src"]
    },
    "composite": true
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../packages/shared" }
  ],
  "exclude": ["node_modules", "dist"]
}

{
  "name": "@ai-writer/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit",
    "db:migrate": "wrangler d1 execute ai-writer-db --local --file=./src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute ai-writer-db --remote --file=./src/db/schema.sql"
  },
  "dependencies": {
    "@ai-writer/shared": "*",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.95.0"
  }
}
